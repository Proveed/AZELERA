<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="com.azelera.tv">
    <uses-permission android:name="android.permission.INTERNET" />
    <application
        android:banner="@drawable/app_banner"
        android:label="Azelera Player"
        android:theme="@style/Theme.AppCompat.NoActionBar">
        <activity android:name=".MainActivity" android:exported="true" android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
